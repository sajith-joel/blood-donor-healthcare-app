.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini

# Firebase
.firebase/

# Build
build/
*.apk
*.aab
*.ipa
"@ | Out-File -FilePath .gitignore -Encoding UTF8